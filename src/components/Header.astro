---
import { navItems as defaultNavItems, navCta as defaultNavCta } from '@content/site';

type NavItem = {
  label: string;
  href: string;
};

type NavCta = {
  label: string;
  href: string;
};

const {
  navItems = defaultNavItems,
  navCta = defaultNavCta,
  homeHref = '#top',
} = Astro.props as {
  navItems?: NavItem[];
  navCta?: NavCta;
  homeHref?: string;
};
---

<div class="scroll-progress" aria-hidden="true"></div>

<header class="site-header" aria-label="Primary navigation" data-header>
  <a class="brand-mark" href={homeHref} aria-label="Real Luxury Media home">
    <img
      src="/assets/real-luxury-media-logo.png"
      alt="Real Luxury Media"
      width="100"
      height="60"
    />
  </a>
  <nav class="nav-links" aria-label="Page sections">
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
  <a class="nav-cta" href={navCta.href}>{navCta.label}</a>
</header>

<script is:inline>
  (() => {
    const init = () => {
      const header = document.querySelector('[data-header]');
      const hero = document.querySelector('.hero-section, [data-banner], .rhero');
      const progress = document.querySelector('.scroll-progress');
      if (!header) return;

      // Header is blended over the hero, then solidifies once you've scrolled
      // most of the way through it. Tied to the hero's measured height so it
      // works for both the tall video banner and the standard hero.
      let ticking = false;
      const apply = () => {
        const heroH = hero ? hero.getBoundingClientRect().height : 0;
        const trigger = heroH > 0 ? Math.max(80, heroH * 0.6) : 80;
        header.classList.toggle('is-scrolled', window.scrollY > trigger);

        if (progress) {
          const max =
            document.documentElement.scrollHeight - window.innerHeight;
          const ratio = max > 0 ? Math.min(1, window.scrollY / max) : 0;
          progress.style.transform = 'scaleX(' + ratio + ')';
        }
        ticking = false;
      };

      window.addEventListener(
        'scroll',
        () => {
          if (!ticking) {
            window.requestAnimationFrame(apply);
            ticking = true;
          }
        },
        { passive: true }
      );
      window.addEventListener('resize', apply, { passive: true });
      apply();
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
