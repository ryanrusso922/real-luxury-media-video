---
import { logos } from "@content/site";

const repeatedLogos = [...logos, ...logos];
---

<section class="logo-section" aria-label="Trusted Sarasota operators">
  <p>Trusted by 30+ leading Sarasota operators</p>
  <div class="logo-rail" aria-hidden="true">
    <div class="logo-track">
      {repeatedLogos.map((logo) => (
        <img src={`/logos/${logo}.png`} alt="" loading="lazy" />
      ))}
    </div>
  </div>
</section>
