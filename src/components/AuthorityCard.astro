---
import type { AuthorityCardContent, AuthorityChannel } from '@content/site';

const { authorityCard } = Astro.props as { authorityCard: AuthorityCardContent };

const markerFor = (index: number) => String(index + 1).padStart(2, '0');

const ariaFor = (channel: AuthorityChannel) =>
  `${channel.cta} — ${channel.label} (opens in new tab)`;
---

<section class="authority-card-section" aria-label="Roger's online presence">
  <div class="authority-card" data-reveal>
    <header class="authority-card__head">
      <p class="eyebrow">{authorityCard.eyebrow}</p>
      <h2>{authorityCard.title}</h2>
      {authorityCard.intro && <p class="authority-card__intro">{authorityCard.intro}</p>}
    </header>

    <div class="authority-grid">
      {authorityCard.channels.map((channel, index) => (
        <a
          class={`authority-tile authority-tile--${channel.kind}`}
          href={channel.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={ariaFor(channel)}
        >
          <header class="authority-tile__head">
            <span class="authority-tile__marker" aria-hidden="true">{markerFor(index)}</span>
            <span class="authority-tile__label">{channel.label}</span>
            <span class="authority-tile__mark" aria-hidden="true">
              {channel.kind === 'site' && (
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" role="presentation">
                  <circle cx="12" cy="12" r="9"/>
                  <path d="M3 12h18"/>
                  <path d="M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/>
                </svg>
              )}
              {channel.kind === 'youtube' && (
                <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" role="presentation">
                  <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8ZM9.6 15.6V8.4l6.3 3.6-6.3 3.6Z"/>
                </svg>
              )}
              {channel.kind === 'instagram' && (
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" role="presentation">
                  <rect x="3" y="3" width="18" height="18" rx="5"/>
                  <circle cx="12" cy="12" r="4"/>
                  <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
                </svg>
              )}
            </span>
          </header>

          <div class="authority-tile__body">
            <p class={`authority-tile__anchor${channel.anchorMono ? ' authority-tile__anchor--mono' : ''}`}>
              {channel.anchor}
            </p>
            <p class="authority-tile__primary">{channel.primary}</p>
            <p class="authority-tile__note">{channel.primaryNote}</p>
            {channel.supporting && (
              <p class="authority-tile__supporting">{channel.supporting}</p>
            )}
          </div>

          <p class="authority-tile__cta">
            <span>{channel.cta}</span>
            <span class="authority-tile__arrow" aria-hidden="true">→</span>
          </p>
        </a>
      ))}
    </div>
  </div>
</section>
