---
import type { ProofBandContent, ProofStat } from '@content/site';

const { proofBand, proofStats } = Astro.props as {
  proofBand: ProofBandContent;
  proofStats: ProofStat[];
};

const parseStatValue = (value: string) => {
  const match = value.match(/^(\D*)(\d+(?:\.\d+)?)(\D*)$/);
  if (!match) return { prefix: '', num: value, suffix: '' };
  return { prefix: match[1], num: match[2], suffix: match[3] };
};
---

<section class="proof-band" id="proof" aria-label="Authority Day campaign proof">
  <div class="proof-band__inner">
    <header class="proof-band__head" data-reveal>
      <p class="eyebrow">{proofBand.eyebrow}</p>
    </header>

    <div class="proof-band__stats">
      {
        proofStats.map((stat, i) => {
          const { prefix, num, suffix } = parseStatValue(stat.value);
          return (
            <article class="proof-band__stat" data-reveal style={`--stat-i: ${i}`}>
              <strong aria-label={stat.value}>
                {prefix && <span class="proof-band__stat-prefix" aria-hidden="true">{prefix}</span>}
                <span
                  class="proof-band__stat-num"
                  aria-hidden="true"
                  data-counter
                  data-target={num}
                  data-stat-i={i}
                  style={`min-width: ${num.length}ch`}
                >0</span>
                {suffix && <span class="proof-band__stat-suffix" aria-hidden="true">{suffix}</span>}
              </strong>
              <span class="proof-band__stat-label">{stat.label}</span>
            </article>
          );
        })
      }
    </div>

    <p class="proof-band__caption" data-reveal>{proofBand.caption}</p>
  </div>
</section>

<script>
  const counters = document.querySelectorAll('[data-counter]');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (counters.length === 0) {
    // nothing to do
  } else if (reduced || !('IntersectionObserver' in window)) {
    counters.forEach((el) => {
      if (el instanceof HTMLElement) el.textContent = el.dataset.target ?? '';
    });
  } else {
    const easeOutQuart = (t: number) => 1 - Math.pow(1 - t, 4);

    const run = (el: HTMLElement, target: number, duration: number, delay: number) => {
      let started: number | null = null;
      const tick = (now: number) => {
        if (started === null) started = now;
        const elapsed = now - started - delay;
        if (elapsed < 0) {
          requestAnimationFrame(tick);
          return;
        }
        const t = Math.min(1, elapsed / duration);
        const eased = easeOutQuart(t);
        const current = Math.round(target * eased);
        el.textContent = current.toString();
        if (t < 1) requestAnimationFrame(tick);
        else el.textContent = target.toString();
      };
      requestAnimationFrame(tick);
    };

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const el = entry.target;
          if (!(el instanceof HTMLElement)) continue;

          const target = Number(el.dataset.target ?? '0');
          const statI = Number(el.dataset.statI ?? '0');
          if (Number.isFinite(target)) {
            run(el, target, 1800, statI * 180);
          } else {
            el.textContent = el.dataset.target ?? '';
          }
          observer.unobserve(el);
        }
      },
      { threshold: 0.35 }
    );

    counters.forEach((el) => observer.observe(el));
  }
</script>
