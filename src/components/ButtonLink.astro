---
const {
  href,
  variant = "primary",
  label,
}: {
  href: string;
  variant?: "primary" | "secondary" | "ghost";
  label: string;
} = Astro.props;
---

<a class={`button-link button-link--${variant}`} href={href}>
  <span class="button-link__label">{label}</span>
  <span class="button-link__arrow" aria-hidden="true"></span>
</a>
