---
import ButtonLink from './ButtonLink.astro';
import type { ApplySectionContent } from '@content/site';

const { applySection } = Astro.props as { applySection: ApplySectionContent };
---

<section class="apply-section" id="apply">
  <div class="apply-bg" aria-hidden="true"></div>

  <div class="apply-inner" data-reveal>
    <header class="apply-head">
      <p class="eyebrow">{applySection.eyebrow}</p>
      <h2>{applySection.title}</h2>
    </header>

    <ol class="apply-ledger">
      {applySection.steps.map((step, i) => (
        <li class="apply-ledger__row" data-reveal style={`--step-i: ${i}`}>
          <span class="apply-ledger__num" aria-hidden="true">{step.step.padStart(2, '0')}</span>
          <span class="apply-ledger__title">{step.title}</span>
          <span class="apply-ledger__text">{step.text}</span>
        </li>
      ))}
    </ol>

    <div class="apply-close">
      <ButtonLink href={applySection.primaryHref} label={applySection.primaryCta} />
      <p class="apply-trust">{applySection.trustLine}</p>
    </div>
  </div>
</section>
