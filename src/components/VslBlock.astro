---
import type { VslContent } from '@content/site';

const { vsl } = Astro.props as { vsl: VslContent };

const hasSource = vsl.videoSrcMP4 || vsl.videoSrcWEBM;
const sectionLabel = vsl.title ?? vsl.posterTitle ?? vsl.ariaLabel;

/* Split the caption into a bold lead sentence + a lighter follow so the thesis
   beat lands with real weight contrast. */
const captionMatch = vsl.caption?.match(/^(.*?[.!?])\s+(.*)$/);
const captionLead = captionMatch ? captionMatch[1] : vsl.caption;
const captionRest = captionMatch ? captionMatch[2] : '';
---

<section class="vsl-section" id="vsl" aria-label={sectionLabel}>
  <div class="vsl-shell">
    {vsl.eyebrow && <p class="eyebrow vsl-eyebrow">{vsl.eyebrow}</p>}
    {vsl.title && <h2 class="vsl-title">{vsl.title}</h2>}
    {vsl.subhead && <p class="vsl-subhead">{vsl.subhead}</p>}

    <article
      class="story-video-card story-video-card--vsl"
      data-vsl-priority
    >
      <div
        class="film-frame film-frame--landscape"
        aria-label={vsl.ariaLabel}
        data-video-card={hasSource ? '' : null}
      >
        {hasSource && (
          <video
            class="film-video"
            preload="metadata"
            playsinline
            aria-label={vsl.ariaLabel}
            poster={vsl.poster}
            data-video-main
          >
            {vsl.videoSrcMP4 && <source src={vsl.videoSrcMP4} type="video/mp4" />}
            {vsl.videoSrcWEBM && <source src={vsl.videoSrcWEBM} type="video/webm" />}
          </video>
        )}
        {hasSource && (
          <button
            type="button"
            class="film-surface"
            aria-label={`Pause or resume ${vsl.posterTitle}`}
            data-video-surface
          >
          </button>
        )}
        <div class="film-placeholder" data-video-placeholder>
          <img
            class="film-placeholder__poster"
            src={vsl.poster}
            alt=""
            loading="lazy"
            decoding="async"
            aria-hidden="true"
          />
          <div class="film-grain" aria-hidden="true"></div>

          <div class="film-seal">
            <div class="film-seal__top">
              <span class="film-seal__rule" aria-hidden="true"></span>
              <p class="film-seal__label">{vsl.posterEyebrow}</p>
              <span class="film-seal__rule" aria-hidden="true"></span>
            </div>

            <button
              type="button"
              class="film-seal__mark"
              aria-label={vsl.ariaLabel}
              data-play-trigger
              disabled={!hasSource}
            >
              <span class="film-seal__arrow" aria-hidden="true"></span>
            </button>

            <h3 class="film-seal__title">{vsl.posterTitle}</h3>
          </div>
        </div>
        {hasSource && (
          <div class="film-paused" aria-hidden="true">
            <button
              type="button"
              class="play-button play-button--small play-button--resume"
              aria-label={`Resume ${vsl.posterTitle}`}
              data-resume-trigger
            >
              <span aria-hidden="true"></span>
            </button>
          </div>
        )}
        {hasSource && (
          <div class="film-hud" aria-hidden="true">
            <span class="film-hud__time" data-time-current>0:00</span>
            <button
              type="button"
              class="film-hud__track"
              aria-label={`Scrub ${vsl.posterTitle}`}
              aria-valuemin="0"
              aria-valuemax="100"
              aria-valuenow="0"
              data-progress-track
            >
              <span class="film-hud__fill" data-progress-fill></span>
              <span class="film-hud__playhead" data-progress-playhead></span>
            </button>
            <span class="film-hud__time" data-time-total>0:00</span>
            <div class="film-hud__controls">
              <button type="button" class="film-hud__btn film-hud__speed" data-speed aria-label="Playback speed 1 times">1×</button>
              <button type="button" class="film-hud__btn" data-mute data-on="true" aria-pressed="false" aria-label="Mute">
                <svg class="film-hud__ico film-hud__ico--on" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 5 6 9H2v6h4l5 4V5z" /><path d="M15.5 8.5a5 5 0 0 1 0 7" /><path d="M19 5a9 9 0 0 1 0 14" /></svg>
                <svg class="film-hud__ico film-hud__ico--off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 5 6 9H2v6h4l5 4V5z" /><line x1="23" y1="9" x2="17" y2="15" /><line x1="17" y1="9" x2="23" y2="15" /></svg>
              </button>
              <button type="button" class="film-hud__btn" data-fullscreen aria-label="Enter fullscreen">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 3H5a2 2 0 0 0-2 2v3M16 3h3a2 2 0 0 1 2 2v3M21 16v3a2 2 0 0 1-2 2h-3M3 16v3a2 2 0 0 0 2 2h3" /></svg>
              </button>
            </div>
          </div>
        )}
      </div>
      {vsl.caption && (
        <div class="story-video-copy vsl-caption">
          <p>
            <span class="vsl-caption__lead">{captionLead}</span>
            {captionRest && <span class="vsl-caption__rest"> {captionRest}</span>}
          </p>
        </div>
      )}
    </article>
  </div>
</section>

<script>
  import '../scripts/video-cards.ts';
</script>
