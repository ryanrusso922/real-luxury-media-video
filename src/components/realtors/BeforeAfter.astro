---
const hotspots = [
  {
    n: 1,
    x: 22,
    y: 18,
    label: 'No name above the fold',
    detail: "His face isn't on the page in the first three seconds. The seller can't connect a story to a stranger.",
  },
  {
    n: 2,
    x: 70,
    y: 30,
    label: 'Listings, not legacy',
    detail: "Inventory blocks before any human signal. Looks like every other agent site in the market.",
  },
  {
    n: 3,
    x: 28,
    y: 64,
    label: 'No proof in the room',
    detail: "Eighteen years of sales, no testimonials in view. The skeptic has to scroll for receipts.",
  },
  {
    n: 4,
    x: 76,
    y: 76,
    label: 'Generic CTA',
    detail: '"Contact" instead of a reason to. The hesitant seller closes the tab.',
  },
];
const beforeImg = '/assets/realtors/before.png';
const afterImg = '/assets/pettingell-site.jpg';
const beforeLink = 'https://web.archive.org/web/*/pettingell.com';
const afterLink = 'https://pettingellprofessionals.com';
---

<section id="diagnosis" class="rba-section" data-reveal>
  <div class="rba-shell">
    <header class="rba-head">
      <div class="rba-head__row">
        <span class="rba-head__num">02</span>
        <h2 class="rba-head__title">Your site is beautiful. But where are <em>you</em>?</h2>
      </div>
      <p class="rba-head__lede">
        Same agent. Same listings. Same brokerage. Tap the dots on the <strong>before</strong> to see what was missing — then switch to <strong>after</strong> to see what changed.
      </p>
    </header>

    <div class="rba-frame" data-rba-frame data-state="before">
      <div class="rba-toolbar">
        <span class="rba-toolbar__hint">Tap to switch</span>
        <div class="rba-toggle" role="tablist" aria-label="Compare before and after">
          <button
            type="button"
            role="tab"
            class="rba-toggle__btn is-active"
            data-rba-state="before"
            aria-selected="true"
          >Before</button>
          <button
            type="button"
            role="tab"
            class="rba-toggle__btn"
            data-rba-state="after"
            aria-selected="false"
          >After</button>
        </div>
      </div>

      <div class="rba-stage">
        <div class="rba-stage__layer rba-stage__layer--before" data-rba-layer="before">
          <img src={beforeImg} alt="pettingell.com before the redesign — archived 2019" loading="lazy" />
          {hotspots.map((dot) => (
            <button
              type="button"
              class="rba-hotspot"
              data-rba-hotspot={dot.n}
              data-rba-label={dot.label}
              data-rba-detail={dot.detail}
              style={`left: ${dot.x}%; top: ${dot.y}%;`}
              aria-label={`Diagnosis ${dot.n}: ${dot.label}`}
            >
              <span class="rba-hotspot__num">{dot.n}</span>
            </button>
          ))}
          <div class="rba-callout" data-rba-callout hidden>
            <header class="rba-callout__head">
              <span class="rba-callout__num" data-rba-callout-num>1</span>
              <button class="rba-callout__close" data-rba-callout-close type="button" aria-label="Close annotation">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M6 6l12 12M6 18L18 6"/></svg>
              </button>
            </header>
            <p class="rba-callout__label" data-rba-callout-label></p>
            <p class="rba-callout__detail" data-rba-callout-detail></p>
          </div>
        </div>

        <div class="rba-stage__layer rba-stage__layer--after" data-rba-layer="after">
          <img src={afterImg} alt="pettingellprofessionals.com after the redesign — current live homepage" loading="lazy" />
        </div>
      </div>

      <footer class="rba-footer">
        <span class="rba-footer__meta">Same agent. Same site. One addition.</span>
        <a class="rba-footer__link" href={beforeLink} target="_blank" rel="noopener" data-rba-foot-before>
          Wayback Machine
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7M9 7h8v8"/></svg>
        </a>
        <a class="rba-footer__link rba-footer__link--after" href={afterLink} target="_blank" rel="noopener" data-rba-foot-after>
          Live site
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7M9 7h8v8"/></svg>
        </a>
      </footer>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const frame = document.querySelector('[data-rba-frame]');
    if (!frame) return;
    const buttons = frame.querySelectorAll('[data-rba-state]');
    const hotspots = frame.querySelectorAll('[data-rba-hotspot]');
    const callout = frame.querySelector('[data-rba-callout]');
    const calloutNum = frame.querySelector('[data-rba-callout-num]');
    const calloutLabel = frame.querySelector('[data-rba-callout-label]');
    const calloutDetail = frame.querySelector('[data-rba-callout-detail]');
    const calloutClose = frame.querySelector('[data-rba-callout-close]');

    const setState = (next) => {
      frame.dataset.state = next;
      buttons.forEach((btn) => {
        const isActive = btn.dataset.rbaState === next;
        btn.classList.toggle('is-active', isActive);
        btn.setAttribute('aria-selected', String(isActive));
      });
      hideCallout();
    };

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => setState(btn.dataset.rbaState));
    });

    const showCallout = (n, label, detail) => {
      if (!callout) return;
      if (calloutNum) calloutNum.textContent = String(n);
      if (calloutLabel) calloutLabel.textContent = label;
      if (calloutDetail) calloutDetail.textContent = detail;
      callout.hidden = false;
    };
    const hideCallout = () => {
      if (callout) callout.hidden = true;
    };

    hotspots.forEach((dot) => {
      dot.addEventListener('click', (e) => {
        e.stopPropagation();
        showCallout(
          dot.dataset.rbaHotspot,
          dot.dataset.rbaLabel ?? '',
          dot.dataset.rbaDetail ?? '',
        );
      });
    });

    calloutClose?.addEventListener('click', hideCallout);
    document.addEventListener('click', (e) => {
      if (callout && !callout.contains(e.target) && !e.target.closest('[data-rba-hotspot]')) {
        hideCallout();
      }
    });
  })();
</script>
