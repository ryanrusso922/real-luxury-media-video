---
const hero = {
  eyebrow: 'Authority Day · By application only',
  title: "You're already the best option in your market.",
  body: "This just makes sure everyone who looks you up feels that immediately — before you ever speak.",
  specs: [
    { label: 'On-site',  value: '1 day' },
    { label: 'Delivery', value: '14 days' },
    { label: 'For',      value: 'agents doing $100M+ volume' },
  ],
  primaryCta: { label: 'Take a look', href: '#cost' },
};
---

<section id="top" class="rh-section">
  <div class="rh-shell">
    <p class="rh-eyebrow">
      <span class="rh-eyebrow__bar"></span>
      {hero.eyebrow}
    </p>

    <h1 class="rh-title">{hero.title}</h1>

    <p class="rh-body">{hero.body}</p>

    <dl class="rh-specs">
      {hero.specs.map((spec) => (
        <div class="rh-specs__row">
          <dt>{spec.label}</dt>
          <dd>{spec.value}</dd>
        </div>
      ))}
    </dl>

    <a class="rh-cta" href={hero.primaryCta.href}>
      <span>{hero.primaryCta.label}</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 5v14M5 12l7 7 7-7"/>
      </svg>
    </a>
  </div>
</section>
