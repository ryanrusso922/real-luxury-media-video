---
/* /realtors - "What the whole thing looks like".
   A real ordered sequence (foundation, quarterly capture, market memory),
   so the numbered markers carry information rather than decorate. Closes on the
   August partner-intake note. */

const system = {
  eyebrow: '',
  title: 'What the whole thing looks like.',
  steps: [
    {
      num: '1',
      title: 'Authority Day',
      text: 'First, we build your foundation.',
    },
    {
      num: '2',
      title: 'Every quarter',
      text: 'Our team comes to you and captures everything you need for the next three months in a single day.',
    },
    {
      num: '3',
      title: 'You dominate',
      text: 'Your market feels like they already know you — before you ever meet.',
    },
  ],
  note: {
    lead: 'We are taking on new full-time partners in August',
    rest: '— only once they’ve done their Authority Day first. That’s the foundation everything else is built on.',
    cta: { label: 'Apply for a seat', href: '#apply' },
  },
};
---

<section id="system" class="rsys-section">
  <div class="rsys-shell">
    <header class="rsys-head">
      {system.eyebrow && <p class="rsys-eyebrow">{system.eyebrow}</p>}
      <h2 class="rsys-title">{system.title}</h2>
    </header>

    <ol class="rsys-steps">
      {system.steps.map((step, i) => (
        <li class="rsys-step">
          <span class="rsys-step__num" aria-hidden="true">{step.num}</span>
          <div class="rsys-step__body">
            <h3 class="rsys-step__title">{step.title}</h3>
            <p class="rsys-step__text">{step.text}</p>
          </div>
        </li>
      ))}
    </ol>

    <aside class="rsys-note">
      <p class="rsys-note__text">
        <strong>{system.note.lead}</strong> {system.note.rest}
      </p>
      <a class="rsys-note__cta" href={system.note.cta.href}>
        {system.note.cta.label}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
      </a>
    </aside>
  </div>
</section>
