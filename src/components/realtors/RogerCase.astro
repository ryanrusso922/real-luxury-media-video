---
/* /realtors - Roger Pettingell case study.
   Centered, cinematic: the case-study heading, then the film (the WeTransfer
   cut) as the centerpiece in its native landscape framing, then the 24/7 quote.
   The film frame reuses the proven VSL player markup wired through
   scripts/video-cards.ts. */

const roger = {
  eyebrow: 'Case study',
  name: 'Roger Pettingell.',
  meta: 'Sarasota, FL · $3B+ in career sales',
  quote: 'Jake took everything I built offline and made it visible online. Now it works for me 24/7.',
  attribution: 'Roger Pettingell',
  ctaLabel: 'Apply for a seat',
  ctaHref: '#apply',
  video: {
    poster: '/assets/banner-hero-poster.jpg',
    posterEyebrow: 'Signature Film',
    posterTitle: 'Roger Pettingell',
    ariaLabel: 'Play Roger Pettingell’s signature film',
    mp4: '/videos/banner-hero-1080p.mp4',
    webm: '',
  },
};
---

<section id="case" class="rcase-section">
  <div class="rcase-shell">
    <header class="rcase-head">
      <p class="rcase-eyebrow">{roger.eyebrow}</p>
      <h2 class="rcase-name">{roger.name}</h2>
      <p class="rcase-meta">{roger.meta}</p>
    </header>

    <article class="rcase-film story-video-card" data-video-card>
      <div
        class="film-frame film-frame--landscape"
        aria-label={roger.video.ariaLabel}
      >
        <video
          class="film-video"
          preload="metadata"
          playsinline
          aria-label={roger.video.ariaLabel}
          poster={roger.video.poster}
          data-video-main
        >
          <source src={roger.video.mp4} type="video/mp4" />
          {roger.video.webm && <source src={roger.video.webm} type="video/webm" />}
        </video>

        <button
          type="button"
          class="film-surface"
          aria-label={`Pause or resume ${roger.video.posterTitle}`}
          data-video-surface
        ></button>

        <div class="film-placeholder" data-video-placeholder>
          <img
            class="film-placeholder__poster"
            src={roger.video.poster}
            alt=""
            loading="lazy"
            decoding="async"
            aria-hidden="true"
          />
          <div class="film-grain" aria-hidden="true"></div>

          <div class="film-seal">
            <div class="film-seal__top">
              <span class="film-seal__rule" aria-hidden="true"></span>
              <p class="film-seal__label">{roger.video.posterEyebrow}</p>
              <span class="film-seal__rule" aria-hidden="true"></span>
            </div>

            <button
              type="button"
              class="film-seal__mark"
              aria-label={roger.video.ariaLabel}
              data-play-trigger
            >
              <span class="film-seal__arrow" aria-hidden="true"></span>
            </button>

            <h3 class="film-seal__title">{roger.video.posterTitle}</h3>
          </div>
        </div>

        <div class="film-paused" aria-hidden="true">
          <button
            type="button"
            class="play-button play-button--small play-button--resume"
            aria-label={`Resume ${roger.video.posterTitle}`}
            data-resume-trigger
          >
            <span aria-hidden="true"></span>
          </button>
        </div>

        <div class="film-hud" aria-hidden="true">
          <span class="film-hud__time" data-time-current>0:00</span>
          <button
            type="button"
            class="film-hud__track"
            aria-label={`Scrub ${roger.video.posterTitle}`}
            aria-valuemin="0"
            aria-valuemax="100"
            aria-valuenow="0"
            data-progress-track
          >
            <span class="film-hud__fill" data-progress-fill></span>
            <span class="film-hud__playhead" data-progress-playhead></span>
          </button>
          <span class="film-hud__time" data-time-total>0:00</span>
          <div class="film-hud__controls">
            <button type="button" class="film-hud__btn film-hud__speed" data-speed aria-label="Playback speed 1 times">1×</button>
            <button type="button" class="film-hud__btn" data-mute data-on="true" aria-pressed="false" aria-label="Mute">
              <svg class="film-hud__ico film-hud__ico--on" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 5 6 9H2v6h4l5 4V5z" /><path d="M15.5 8.5a5 5 0 0 1 0 7" /><path d="M19 5a9 9 0 0 1 0 14" /></svg>
              <svg class="film-hud__ico film-hud__ico--off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 5 6 9H2v6h4l5 4V5z" /><line x1="23" y1="9" x2="17" y2="15" /><line x1="17" y1="9" x2="23" y2="15" /></svg>
            </button>
            <button type="button" class="film-hud__btn" data-fullscreen aria-label="Enter fullscreen">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 3H5a2 2 0 0 0-2 2v3M16 3h3a2 2 0 0 1 2 2v3M21 16v3a2 2 0 0 1-2 2h-3M3 16v3a2 2 0 0 0 2 2h3" /></svg>
            </button>
          </div>
        </div>
      </div>
    </article>

    <figure class="rcase-quote">
      <blockquote>&ldquo;{roger.quote}&rdquo;</blockquote>
      <figcaption>{roger.attribution}</figcaption>
    </figure>

    <a class="rcase-cta" href={roger.ctaHref}>
      {roger.ctaLabel}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
  </div>
</section>

<script>
  import '../../scripts/video-cards.ts';
</script>
