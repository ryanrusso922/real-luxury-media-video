---
/* /realtors — Hero (text only, centered, per Jake's direction).
   No video, no buttons: just the line, in your face. Oversized centered type
   (reference composition), then the standalone break that hands into the VSL. */

const hero = {
  lead: 'We keep the best agents top of mind —',
  accent: 'every single week.',
  sub: 'A done-for-you content system for agents doing $100M+.',
  break: 'But before anything else, we start here.',
};
---

<section id="top" class="rhero">
  <div class="rhero__inner">
    <h1 class="rhero__title">
      {hero.lead} <span class="rhero__accent">{hero.accent}</span>
    </h1>
    <p class="rhero__sub">{hero.sub}</p>
  </div>

  <p class="rhero__break">{hero.break}</p>

  <a class="rhero__scroll" href="#vsl" aria-label="Scroll to the overview">
    <span class="rhero__scroll-line" aria-hidden="true"></span>
  </a>
</section>
