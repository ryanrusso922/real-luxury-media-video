---
/* /realtors — The core line (the thesis, kept exactly).
   Editorial pull-quote: serif voice, the emotional hinge in italic, the payoff
   in emerald. The words are Jake's verbatim thesis; emphasis is purely visual. */

const cost = {
  open: "You're already at the top. The listings you lose don't go to better agents — they go to ",
  hinge: 'the one the seller felt they already knew.',
  mid: ' The one they just clicked with. Your numbers can’t beat that feeling. Nothing does — ',
  payoff: 'unless every seller feels like they already know you.',
};
---

<section id="cost" class="rcost-section">
  <blockquote class="rcost-shell">
    <p class="rcost-statement">
      {cost.open}<span class="rcost-hinge">{cost.hinge}</span>{cost.mid}<span class="rcost-emph">{cost.payoff}</span>
    </p>
  </blockquote>
</section>
