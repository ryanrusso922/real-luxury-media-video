---
/* /operators — Section 1: Hero.
   Cinematic manifesto. The headline rises word-by-word out of a living emerald
   aurora, then one action. Copy is verbatim (Jake's line) — the tokeniser only
   splits the existing string into words for the staggered reveal. */

const hero = {
  eyebrow: 'Real Luxury Media',
  lead: 'The content team ',
  accent: 'the best in the business',
  tail: ' actually call.',
  sub: 'We fly out, shoot everything, and don’t leave until you win.',
  ctaLabel: 'Apply for a seat',
  ctaHref: '#apply',
};

type Word = { text: string; accent: boolean };
const toWords = (s: string, accent: boolean): Word[] =>
  s.trim().length ? s.trim().split(/\s+/).map((text) => ({ text, accent })) : [];

const words: Word[] = [
  ...toWords(hero.lead, false),
  ...toWords(hero.accent, true),
  ...toWords(hero.tail, false),
];
const fullTitle = `${hero.lead}${hero.accent}${hero.tail}`;
---

<section id="top" class="ohero">
  <div class="ohero__aurora" aria-hidden="true"></div>

  <div class="ohero__inner">
    <p class="ohero__eyebrow">
      <span class="ohero__eyebrow-tick" aria-hidden="true"></span>
      {hero.eyebrow}
    </p>

    <h1 class="ohero__title">
      <span class="ohero__sr">{fullTitle}</span>
      <span class="ohero__words" aria-hidden="true">
        {words.map((w, i) => (
          <span class="ohero__w" style={`--wi:${i}`}>
            <span class={`ohero__wi${w.accent ? ' ohero__wi--accent' : ''}`}>{w.text}</span>
          </span>
        ))}
      </span>
    </h1>

    <p class="ohero__sub">{hero.sub}</p>

    <a class="ohero__cta" href={hero.ctaHref}>
      <span class="ohero__cta-label">{hero.ctaLabel}</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
  </div>
</section>
