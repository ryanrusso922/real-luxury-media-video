---
/* /operators — Section 6: The close.
   A short, human invitation, then the one action. Framed as a deliberate
   finale — an emerald aurora bookends the hero at the top of the page. */

const close = {
  eyebrow: 'By application only',
  lead: 'Tell us a bit about you.',
  line: 'If you’re a fit, we’ll get on a call and map out exactly what it takes for you to win online.',
  soft: 'And if we’re not the ones to build it with you — we’ll point you in the right direction anyway.',
  ctaLabel: 'Apply for a seat',
  ctaHref: 'mailto:Jake@realluxurymedia.com?subject=Apply%20for%20a%20seat',
  trust: 'A short form to start. If it’s not a fit, we’ll say so.',
};
---

<section id="apply" class="oclose">
  <div class="oclose__aurora" aria-hidden="true"></div>

  <div class="oclose__panel" data-reveal>
    <p class="oclose__eyebrow">
      <span class="oclose__rule" aria-hidden="true"></span>
      {close.eyebrow}
      <span class="oclose__rule" aria-hidden="true"></span>
    </p>
    <h2 class="oclose__lead">{close.lead}</h2>
    <p class="oclose__line">{close.line}</p>
    <p class="oclose__line oclose__line--soft">{close.soft}</p>
    <a class="oclose__cta" href={close.ctaHref}>
      <span class="oclose__cta-label">{close.ctaLabel}</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
    <p class="oclose__trust">{close.trust}</p>
  </div>
</section>
