---
import type { StoryContent } from '@content/site';

const { story } = Astro.props as { story: StoryContent };
---

<section class="story-section" id="case">
  <div class="story-shell">
    <div class="story-copy" data-reveal>
      <header class="story-heading">
        <p class="eyebrow">{story.eyebrow}</p>
        <h2 class="story-title">
          {story.titleLines.map((line) => <span>{line}</span>)}
        </h2>
      </header>

      <p class="story-intro">{story.intro}</p>
      <p class="story-body">{story.body}</p>
    </div>

    <aside class="legacy-panel" data-reveal>
      <ul class="legacy-panel__results">
        {story.results.map((result, i) => (
          <li style={`--result-i: ${i}`}>
            <span class="legacy-panel__results-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <span class="legacy-panel__results-text">{result}</span>
          </li>
        ))}
      </ul>

      <blockquote>
        <p>{story.quote}</p>
        <footer>
          <strong>{story.quoteAuthor}</strong>
          <span>{story.quoteRole}</span>
        </footer>
      </blockquote>
    </aside>
  </div>
</section>
