---
import type { ProcessSectionContent } from '@content/site';

const { process } = Astro.props as { process: ProcessSectionContent };
---

<section class="process-section" id="process">
  <div class="process-head" data-reveal>
    <p class="eyebrow">{process.eyebrow}</p>
    <h2>{process.title}</h2>
  </div>

  <ol class="process-timeline">
    {process.steps.map((item, i) => (
      <li class="process-row" data-reveal style={`--row-i: ${i}`}>
        <div class="process-row__rail" aria-hidden="true">
          <span class="process-row__dot"></span>
          <span class="process-row__line"></span>
        </div>
        <div class="process-row__num" aria-hidden="true">{item.step}</div>
        <article class="process-row__body">
          <h3>{item.title}</h3>
          <p>{item.text}</p>
          {item.note && (
            <p class="process-note">
              <span class="process-note__mark" aria-hidden="true">→</span>
              {item.note}
            </p>
          )}
        </article>
      </li>
    ))}
  </ol>
</section>
